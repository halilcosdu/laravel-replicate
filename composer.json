{
    "name": "halilcosdu/laravel-replicate",
    "description": "Laravel client for Replicate predictions, files, models, trainings, and signed webhooks",
    "keywords": [
        "ai",
        "api-client",
        "laravel",
        "replicate",
        "webhooks"
    ],
    "homepage": "https://github.com/halilcosdu/laravel-replicate",
    "license": "MIT",
    "authors": [
        {
            "name": "Halil Cosdu",
            "email": "halilcosdu@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^11.0||^12.0||^13.0",
        "illuminate/http": "^11.0||^12.0||^13.0",
        "illuminate/support": "^11.0||^12.0||^13.0",
        "spatie/laravel-package-tools": "^1.16"
    },
    "require-dev": {
        "larastan/larastan": "^2.9||^3.0",
        "laravel/pint": "^1.14",
        "nunomaduro/collision": "^8.1.1||^9.0",
        "orchestra/testbench": "^9.0.0||^10.0.0||^11.0.0",
        "pestphp/pest": "^3.8||^4.0",
        "pestphp/pest-plugin-arch": "^3.1||^4.0",
        "pestphp/pest-plugin-laravel": "^3.2||^4.0",
        "phpstan/extension-installer": "^1.3",
        "phpstan/phpstan-deprecation-rules": "^1.1||^2.0",
        "phpstan/phpstan-phpunit": "^1.3||^2.0"
    },
    "autoload": {
        "psr-4": {
            "HalilCosdu\\Replicate\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "HalilCosdu\\Replicate\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@composer run prepare",
        "clear": "@php vendor/bin/testbench package:purge-laravel-replicate --ansi",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "build": [
            "@composer run prepare",
            "@php vendor/bin/testbench workbench:build --ansi"
        ],
        "start": [
            "Composer\\Config::disableProcessTimeout",
            "@composer run build",
            "@php vendor/bin/testbench serve"
        ],
        "analyse": "vendor/bin/phpstan analyse",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage --coverage-html build/coverage --coverage-text=build/coverage.txt --coverage-clover build/logs/clover.xml",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "HalilCosdu\\Replicate\\ReplicateServiceProvider"
            ],
            "aliases": {
                "Replicate": "HalilCosdu\\Replicate\\Facades\\Replicate"
            }
        }
    },
    "prefer-stable": true
}
